COMPOSE_PROJECT_NAME=czech-go-system

# Shared docker network used by nginx-proxy/acme-companion on the EC2 host.
PROXY_NETWORK=proxy

# AWS / ECR
AWS_REGION=eu-central-1
AWS_ACCOUNT_ID=123456789012
ECR_REGISTRY=${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com

TZ=Europe/Prague
LE_EMAIL=admin@example.com

# Public domains
BACKEND_HOST=api.example.com
CMS_HOST=cms.example.com

# ECR repos + immutable release tag
BACKEND_IMAGE_REPO=${ECR_REGISTRY}/czech-go-system-backend
CMS_IMAGE_REPO=${ECR_REGISTRY}/czech-go-system-cms
IMAGE_TAG=20260422-001
IMAGE_PLATFORM=linux/arm64

# CMS server-side runtime values
API_BASE_URL=http://backend:8080
CMS_ADMIN_TOKEN=dev-admin-token
CMS_BASIC_AUTH_USER=cmsadmin
CMS_BASIC_AUTH_PASSWORD=change-me

# RDS / Postgres
# Example value:
# postgres://app_user:change-me@mydb.xxxxxx.eu-central-1.rds.amazonaws.com:5432/czech_go_system?sslmode=require
DATABASE_URL=postgres://app_user:change-me@mydb.xxxxxx.eu-central-1.rds.amazonaws.com:5432/czech_go_system?sslmode=require

# First deploy mode: keep uploads and transcription on the simpler local/dev path.
TRANSCRIBER_PROVIDER=dev
REQUIRE_REAL_TRANSCRIPT=false
ATTEMPT_UPLOAD_PROVIDER=local
TTS_PROVIDER=dev
POLLY_VOICE_ID=Jitka
POLLY_SAMPLE_RATE=22050

# Fill these in later when switching to real S3 upload + Amazon Transcribe.
ATTEMPT_AUDIO_S3_BUCKET=
ATTEMPT_AUDIO_S3_PREFIX=attempt-audio
ATTEMPT_UPLOAD_URL_TTL=5m
TRANSCRIBE_OUTPUT_BUCKET=
TRANSCRIBE_OUTPUT_PREFIX=transcribe-output
TRANSCRIBE_LANGUAGE_CODE=cs-CZ
TRANSCRIBE_POLL_INTERVAL=5s
TRANSCRIBE_TIMEOUT=2m
