COMPOSE_PROJECT_NAME=czech-go-system

POSTGRES_DB=czech_go_system
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432

BACKEND_PORT=8080
CMS_PORT=3000

API_BASE_URL=http://backend:8080
CMS_ADMIN_TOKEN=dev-admin-token
CMS_BASIC_AUTH_USER=
CMS_BASIC_AUTH_PASSWORD=

TRANSCRIBER_PROVIDER=dev
REQUIRE_REAL_TRANSCRIPT=false
ATTEMPT_UPLOAD_PROVIDER=local
TTS_PROVIDER=dev
POLLY_VOICE_ID=Jitka
POLLY_SAMPLE_RATE=22050

# Set these when you want the backend container to use real AWS services.
AWS_REGION=eu-central-1
AWS_PROFILE=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_EC2_METADATA_DISABLED=true
ATTEMPT_AUDIO_S3_BUCKET=czech-go-app
ATTEMPT_AUDIO_S3_PREFIX=attempt-audio
ATTEMPT_UPLOAD_URL_TTL=15m
# Optional. Leave empty to auto-select S3 playback when ATTEMPT_UPLOAD_PROVIDER=s3.
# Set to local only when forcing backend-local stream URLs.
ATTEMPT_AUDIO_URL_PROVIDER=
TRANSCRIBE_OUTPUT_BUCKET=czech-go-app
TRANSCRIBE_OUTPUT_PREFIX=transcribe-output
TRANSCRIBE_LANGUAGE_CODE=cs-CZ
TRANSCRIBE_POLL_INTERVAL=5s
TRANSCRIBE_TIMEOUT=3m

# Persistent HMAC secret for signed audio playback URLs.
# Generate via: openssl rand -hex 32
# Required by backend startup, including local compose.
AUDIO_SIGN_SECRET=replace-with-openssl-rand-hex-32
